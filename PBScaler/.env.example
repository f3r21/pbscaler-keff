# Variables de entorno consumidas por PBScaler-keff en runtime.
# Copiar a .env (gitignored) y editar para tu cluster, o exportar directamente.

# Kubernetes
K8S_NAMESPACE=online-boutique
K8S_CONFIG=~/.kube/config

# Prometheus
PROM_RANGE_URL=http://localhost:9090/api/v1/query_range
PROM_QUERY_URL=http://localhost:9090/api/v1/query

# Selección de controlador. Uno de:
#   PBScaler            (baseline vanilla)
#   PBScaler-keff       (esta tesis)
#   NaiveTemporalGate   (4to baseline, cooldown simple post scale-up)
#   KHPA                (wrapper del HPA nativo de Kubernetes)
PBSCALER_CONTROLLER=PBScaler-keff
